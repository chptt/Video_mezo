		"devdoc": {
			"details": "Mezo is a Bitcoin-first EVM-compatible chain where BTC is the native      gas token (18 decimals). This contract is identical in logic to the      Arbitrum version but is deployed on Mezo Testnet (chainId 31611) or      Mezo Mainnet (chainId 31612).      Deploy via Remix:        1. Set compiler to 0.8.24, enable optimizer (200 runs)        2. In \"Deploy & Run\", select \"Injected Provider - MetaMask\"        3. Make sure MetaMask is on Mezo Testnet (chainId 31611)        4. Constructor args:             _treasury  = your treasury wallet address             _feeBps    = 1000  (= 10%)             _revenueCapWei = revenue cap in wei (BTC, 18 decimals)                             e.g. for $20 cap at $100,000/BTC:                             0.0002 BTC = 200000000000000 wei",
			"kind": "dev",
			"methods": {
				"createCampaign(string,uint256,uint256)": {
					"params": {
						"durationSeconds": "How long access lasts after purchase",
						"metadataCID": "IPFS CID of the encrypted metadata JSON",
						"priceWei": "Access price in wei (BTC, 18 decimals)"
					}
				},
				"purchaseAccess(uint256)": {
					"params": {
						"id": "Campaign ID"
					}
				}
			},
			"title": "PrivateStreamMezo",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"createCampaign(string,uint256,uint256)": {
					"notice": "Create a new campaign. One campaign per wallet."
				},
				"deactivateCampaign(uint256)": {
					"notice": "Creator can deactivate their own campaign "
				},
				"getCampaign(uint256)": {
					"notice": "Get full campaign data "
				},
				"getCampaignByCreator(address)": {
					"notice": "Get the campaign ID owned by a creator (0 if none) "
				},
				"hasAccess(uint256,address)": {
					"notice": "Check if a buyer has valid, unexpired access "
				},
				"purchaseAccess(uint256)": {
					"notice": "Purchase access to a campaign. Send exactly priceWei BTC."
				},
				"totalCampaigns()": {
					"notice": "Total number of campaigns ever created "
				}
			},
			"notice": "Privacy-preserving encrypted video access platform on Mezo.",
			"version": 1
